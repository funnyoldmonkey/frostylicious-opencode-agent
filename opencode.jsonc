{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
	"google": {
	  "options": {
		"baseURL": "http://127.0.0.1:5555"
	  }
	}
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": false
    },
	"chrome-devtools": {
	  "type": "local",
	  "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"],
	  "enabled": true
	}
  }
}